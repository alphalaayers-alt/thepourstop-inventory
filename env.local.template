# Copy this file to `.env.local` in the project root and fill in your values.
# Get these from: Supabase Dashboard → Project Settings → Configuration → API Keys

NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co

# Use publishable key (sb_publishable_...) OR legacy anon JWT key
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_your_key_here

# Use secret key (sb_secret_...) OR legacy service_role JWT key — server only
SUPABASE_SERVICE_ROLE_KEY=sb_secret_your_key_here